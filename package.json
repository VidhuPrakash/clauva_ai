{
  "name": "clauva.ai",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "commit": "cz"
  },
  "lint-staged": {
    "backend/**/*.py": [
      "python -m ruff check --fix",
      "python -m ruff format"
    ],
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "./frontend/node_modules/.bin/eslint --fix --no-warn-ignored --config ./frontend/eslint.config.mjs",
      "./frontend/node_modules/.bin/prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0"
  }
}
